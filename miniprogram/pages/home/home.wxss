.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 26rpx;
  padding: 34rpx 32rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.94), rgba(15, 159, 143, 0.9));
  box-shadow: 0 20rpx 46rpx rgba(37, 99, 235, 0.22);
}

.hero-copy {
  min-width: 0;
}

.hero-card .page-title {
  margin-top: 8rpx;
  font-size: 42rpx;
}

.hero-card .page-subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
}

.avatar-box {
  flex: none;
}

.hero-avatar,
.hero-avatar-img {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  flex: none;
}

.hero-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 5rpx solid rgba(255, 255, 255, 0.82);
  background: #2dd4bf;
  color: #06383f;
  font-size: 45rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(15, 35, 65, 0.18);
}

.hero-avatar-img {
  border: 5rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 10rpx 24rpx rgba(15, 35, 65, 0.18);
}

.living-grid {
  display: flex;
  gap: 16rpx;
}

.living-item {
  min-width: 0;
  flex: 1;
  padding: 22rpx 10rpx;
  border-radius: 18rpx;
  background: #f5f9fd;
  text-align: center;
}

.living-label,
.living-value {
  display: block;
}

.living-label {
  color: #64748b;
  font-size: 23rpx;
  font-weight: 800;
}

.living-value {
  margin-top: 10rpx;
  color: #172033;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -9rpx;
}

.feature-card {
  width: calc(50% - 18rpx);
  min-height: 186rpx;
  margin: 9rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 34rpx rgba(31, 54, 82, 0.1);
  box-sizing: border-box;
}

.feature-card:active {
  transform: translateY(1rpx);
}

.feature-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.repair .feature-icon {
  background: #f97373;
}

.change .feature-icon {
  background: #2563eb;
}

.visit .feature-icon {
  background: #f5a524;
}

.profile .feature-icon {
  background: #0f9f8f;
}

.feature-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.feature-desc {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
}
