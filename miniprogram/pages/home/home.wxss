.glow-orb {
  position: absolute;
  width: 450rpx;
  height: 450rpx;
  border-radius: 50%;
  background: rgba(45, 212, 191, 0.06);
  filter: blur(80rpx);
  top: 150rpx;
  right: -100rpx;
  pointer-events: none;
  z-index: 0;
}

.header-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.6);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.25);
  backdrop-filter: blur(16rpx);
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.user-intro {
  display: flex;
  flex-direction: column;
}

.eyebrow {
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: #38bdf8;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.hero-avatar,
.hero-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  flex: none;
}

.hero-avatar {
  text-align: center;
  line-height: 120rpx;
  color: #050c1d;
  background: linear-gradient(135deg, #38bdf8, #2dd4bf);
  font-size: 44rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 20rpx rgba(56, 189, 248, 0.2);
}

.hero-avatar-img {
  object-fit: cover;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.3);
}

.info-card {
  background: rgba(15, 23, 42, 0.5) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.12) !important;
  border-radius: 24rpx !important;
  padding: 36rpx !important;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.living-grid {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.living-item {
  flex: 1;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  text-align: center;
}

.living-label {
  display: block;
  color: #94a3b8;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.living-value {
  display: block;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 24rpx;
  color: #64748b;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  margin: 40rpx 10rpx 20rpx;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.5);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  text-align: center;
  line-height: 72rpx;
  color: #050c1d;
  font-size: 36rpx;
  font-weight: 800;
  flex: none;
}

.repair .action-icon {
  background: linear-gradient(135deg, #fb7185, #f43f5e);
  box-shadow: 0 8rpx 16rpx rgba(244, 63, 94, 0.2);
}

.change .action-icon {
  background: linear-gradient(135deg, #38bdf8, #0ea5e9);
  box-shadow: 0 8rpx 16rpx rgba(14, 165, 233, 0.2);
}

.visit .action-icon {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  box-shadow: 0 8rpx 16rpx rgba(245, 158, 11, 0.2);
}

.profile .action-icon {
  background: linear-gradient(135deg, #2dd4bf, #0d9488);
  box-shadow: 0 8rpx 16rpx rgba(13, 148, 136, 0.2);
}

.action-text-area {
  flex: 1;
  margin-left: 28rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.action-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.action-arrow {
  color: #475569;
  font-size: 28rpx;
  font-weight: 700;
}
