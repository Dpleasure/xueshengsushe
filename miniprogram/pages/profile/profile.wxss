.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 26rpx;
  padding: 38rpx 30rpx 34rpx;
}

.avatar-wrap {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 22rpx;
  border-radius: 50%;
  flex: none;
}

.avatar,
.avatar-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 5rpx solid #ffffff;
  background: linear-gradient(135deg, #2dd4bf, #2563eb);
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 32rpx rgba(37, 99, 235, 0.2);
}

.avatar-img {
  border: 5rpx solid #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(37, 99, 235, 0.2);
  box-sizing: border-box;
}

.avatar-action {
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  transform: translateX(-50%);
  min-width: 112rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(23, 32, 51, 0.86);
  color: #ffffff;
  text-align: center;
  font-size: 18rpx;
  line-height: 34rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.profile-name {
  color: #172033;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
}

.profile-role {
  margin-top: 10rpx;
  color: #0f9f8f;
  font-size: 25rpx;
  font-weight: 900;
}

.profile-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
  font-weight: 700;
}

.stat-grid {
  display: flex;
  gap: 14rpx;
}

.stat-card {
  min-width: 0;
  flex: 1;
  padding: 22rpx 12rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.88);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.94);
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(31, 54, 82, 0.08);
  box-sizing: border-box;
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  color: #172033;
  font-size: 27rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 700;
}

.logout-btn {
  width: 100%;
  margin-top: 16rpx;
}
