page {
  min-height: 100%;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
  background: #eef5fb;
  font-size: 28rpx;
}

.page,
.login-page {
  position: relative;
  min-height: 100vh;
  padding: 32rpx 28rpx 150rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.page-bg {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  display: block;
}

.page-bg-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1;
  background:
    linear-gradient(180deg, rgba(15, 36, 58, 0.34), rgba(238, 245, 251, 0.9) 42%, #eef5fb 78%),
    rgba(241, 247, 252, 0.3);
}

.content-layer {
  position: relative;
  z-index: 2;
}

.section {
  margin-bottom: 28rpx;
}

.page-hero {
  padding: 18rpx 6rpx 30rpx;
}

.page-title {
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.16;
  text-shadow: 0 6rpx 18rpx rgba(15, 35, 65, 0.2);
}

.page-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.55;
  text-shadow: 0 4rpx 14rpx rgba(15, 35, 65, 0.2);
}

.kicker {
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
}

.kicker.light {
  margin-bottom: 8rpx;
  color: rgba(255, 255, 255, 0.9);
}

.card,
.list-card {
  box-sizing: border-box;
  border: 1rpx solid rgba(226, 232, 240, 0.88);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(31, 54, 82, 0.12);
}

.card {
  padding: 30rpx;
}

.list-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
}

.card-header,
.list-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.card-header {
  margin-bottom: 22rpx;
}

.header-left {
  min-width: 0;
}

.card-title,
.list-title {
  margin-top: 8rpx;
  margin-bottom: 0;
  color: #172033;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.25;
}

.section-heading {
  margin: 8rpx 4rpx 18rpx;
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #475569;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.3;
}

.input,
.textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d7e0ea;
  border-radius: 16rpx;
  background: #ffffff;
  color: #172033;
  font-size: 28rpx;
  font-weight: 600;
}

.input,
.picker {
  height: 92rpx;
  min-height: 92rpx;
  padding: 0 26rpx;
  line-height: 92rpx;
}

.textarea {
  height: 190rpx;
  min-height: 190rpx;
  padding: 22rpx 26rpx;
  line-height: 1.55;
}

.input-placeholder,
.textarea-placeholder {
  color: #9aa8b8;
  font-weight: 500;
}

.primary-btn,
.secondary-btn,
.danger-btn,
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.primary-btn {
  border: 0;
  background: linear-gradient(135deg, #2563eb, #1d75f0);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(37, 99, 235, 0.24);
}

.primary-btn:active {
  transform: translateY(1rpx);
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.22);
}

.secondary-btn {
  border: 1rpx solid rgba(37, 99, 235, 0.22);
  background: #eaf2ff;
  color: #1d4ed8;
}

.danger-btn,
.logout-btn {
  border: 1rpx solid rgba(220, 38, 38, 0.2);
  background: #fff1f2;
  color: #dc2626;
}

button::after {
  border: none;
}

button[disabled],
.primary-btn[disabled] {
  opacity: 0.55;
  color: rgba(255, 255, 255, 0.86);
}

.row,
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 72rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #edf2f7;
  font-size: 26rpx;
  line-height: 1.45;
}

.info-row:last-child,
.row:last-child {
  border-bottom: none;
}

.compact-row {
  min-height: 54rpx;
  padding: 6rpx 0;
}

.row-label,
.info-label {
  flex: none;
  color: #64748b;
  font-weight: 700;
}

.row-value,
.info-value {
  flex: 1;
  color: #172033;
  text-align: right;
  font-weight: 800;
  word-break: break-all;
}

.accent,
.text-accent {
  color: #0f9f8f !important;
}

.muted {
  color: #64748b;
}

.empty,
.empty-state {
  padding: 42rpx 20rpx;
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 108rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.badge-pending {
  background: #fff2bf;
  color: #92550b;
}

.badge-approved,
.badge-completed {
  background: #d8f7ea;
  color: #047857;
}

.badge-rejected {
  background: #ffe4e6;
  color: #be123c;
}

.badge-processing {
  background: #dff4ff;
  color: #075985;
}

.item-title {
  flex: 1;
  min-width: 0;
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.desc {
  margin-top: 16rpx;
  color: #526173;
  font-size: 26rpx;
  line-height: 1.6;
}

.time {
  margin-top: 14rpx;
  color: #8794a5;
  font-size: 24rpx;
  line-height: 1.4;
}

.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
