.tab-shell {
  padding: 0 18rpx 16rpx;
  background: transparent;
}

.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 112rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.88);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(31, 54, 82, 0.08);
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #64748b;
  transform: translateY(0) scale(1);
  transition: transform 160ms ease, color 160ms ease;
}

.tab-item.active {
  color: #2563eb;
  transform: translateY(-6rpx);
}

.tab-item.pressed {
  transform: translateY(-3rpx) scale(0.94);
}

.tab-item.active.pressed {
  transform: translateY(-7rpx) scale(0.96);
}

.icon-wrap {
  width: 54rpx;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: transparent;
  transition: background 160ms ease, box-shadow 160ms ease;
}

.tab-item.active .icon-wrap {
  background: #eaf2ff;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.14);
}

.tab-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  color: currentColor;
  box-sizing: border-box;
}

.icon-home {
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 5rpx;
  transform: translateY(5rpx);
}

.icon-home::before {
  content: "";
  position: absolute;
  left: 3rpx;
  top: -13rpx;
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
}

.icon-repair {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
  transform: rotate(45deg);
}

.icon-repair::before {
  content: "";
  position: absolute;
  left: 9rpx;
  top: -10rpx;
  width: 5rpx;
  height: 14rpx;
  border-radius: 6rpx;
  background: currentColor;
}

.icon-change::before,
.icon-change::after {
  content: "";
  position: absolute;
  left: 1rpx;
  width: 30rpx;
  height: 10rpx;
  border-top: 4rpx solid currentColor;
}

.icon-change::before {
  top: 6rpx;
  border-right: 4rpx solid currentColor;
  transform: skewX(-18deg);
}

.icon-change::after {
  top: 22rpx;
  border-left: 4rpx solid currentColor;
  transform: skewX(-18deg);
}

.icon-visit {
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.icon-visit::before {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 8rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-visit::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 20rpx;
  width: 14rpx;
  height: 8rpx;
  border-radius: 10rpx 10rpx 0 0;
  background: currentColor;
}

.icon-profile {
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.icon-profile::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 6rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-profile::after {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 20rpx;
  width: 16rpx;
  height: 8rpx;
  border-radius: 10rpx 10rpx 0 0;
  background: currentColor;
}

.tab-text {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 800;
}
